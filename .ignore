# Generic ignore file for local tooling
# Keeps environment secrets, dependencies, builds, and caches out of indexing/upload.

# Environment and secrets
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build outputs and caches
dist/
out/
coverage/
.cache/
.local/
.tmp/
tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# TypeScript
tsconfig.tsbuildinfo
*.tsbuildinfo

# Test artifacts
test-results.xlsx
test-students.xlsx
